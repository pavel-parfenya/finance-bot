{
  "kind": "collectionType",
  "collectionName": "features",
  "info": {
    "singularName": "feature",
    "pluralName": "features",
    "displayName": "Feature",
    "description": "Фичи тарифов (каталог для выбора в планах и гейтинга функций)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "label": {
      "type": "string",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "pricings": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::pricing.pricing",
      "mappedBy": "planFeatures"
    }
  }
}
