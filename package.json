{
  "name": "finance-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram bot that parses expense messages and tracks finances",
  "packageManager": "npm@9.6.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo build --filter=apps-api...",
    "build:bot": "turbo build --filter=apps-bot...",
    "build:landing": "turbo build --filter=apps-landing...",
    "build:miniapp": "turbo build --filter=apps-miniapp...",
    "build:cms": "turbo build --filter=apps-cms...",
    "start": "concurrently -n api,bot,landing,cms -c blue,green,yellow,magenta \"npm run start -w apps-api\" \"npm run start -w apps-bot\" \"npm run start -w apps-landing\" \"npm run start -w apps-cms\"",
    "start:api": "npm run start -w apps-api",
    "start:bot": "npm run start -w apps-bot",
    "start:landing": "npm run start -w apps-landing",
    "start:cms": "npm run start -w apps-cms",
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=apps-api",
    "dev:bot": "turbo dev --filter=apps-bot",
    "dev:miniapp": "turbo dev --filter=apps-miniapp",
    "dev:landing": "turbo dev --filter=apps-landing",
    "dev:cms": "turbo dev --filter=apps-cms",
    "lint": "turbo lint",
    "lint:fix": "eslint packages/shared packages/shared-types packages/shared-utils packages/server-core apps/api apps/bot apps/miniapp --fix",
    "format": "prettier --write \"packages/**/*.ts\" \"apps/**/*.{ts,vue,html,css}\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"apps/**/*.{ts,vue,html,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "DB=$(grep -E '^DATABASE_URL=' .env | head -1 | cut -d= -f2- | tr -d '\"'); psql \"$DB\" -f apps/cms/src/seeds/seed.sql && psql \"$DB\" -f apps/cms/src/seeds/seed-plan-features.sql",
    "migrations": "npm run migrations -w @finance-bot/server-core",
    "migrations:generate": "npm run migrations:generate -w @finance-bot/server-core",
    "migrations:revert": "npm run migrations:revert -w @finance-bot/server-core",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "concurrently": "^9.1.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
