{
  "name": "finance-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Telegram bot that parses expense messages and logs them to Google Sheets",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @finance-bot/shared && npm run build -w apps-client && npm run build -w apps-server",
    "build:server": "npm run build -w @finance-bot/shared && npm run build -w apps-server",
    "start": "npm run start -w apps-server",
    "dev": "concurrently \"npm run dev -w apps-server\" \"npm run dev -w apps-client\"",
    "dev:server": "npm run dev -w apps-server",
    "dev:client": "npm run dev -w apps-client",
    "lint": "eslint packages/shared apps/server apps/client",
    "lint:fix": "eslint packages/shared apps/server apps/client --fix",
    "format": "prettier --write \"packages/**/*.ts\" \"apps/**/*.{ts,vue,html,css}\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"apps/**/*.{ts,vue,html,css}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.vue": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.1.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0"
  }
}
