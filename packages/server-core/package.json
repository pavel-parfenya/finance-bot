{
  "name": "@finance-bot/server-core",
  "version": "1.0.0",
  "private": true,
  "description": "Shared DB, repositories, domain services for finance-bot API and bot",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "migrations": "typeorm-ts-node-commonjs -d src/database/data-source.cli.ts migration:run",
    "migrations:generate": "typeorm-ts-node-commonjs -d src/database/data-source.cli.ts migration:generate src/database/migrations/migration",
    "migrations:revert": "typeorm-ts-node-commonjs -d src/database/data-source.cli.ts migration:revert"
  },
  "dependencies": {
    "@finance-bot/shared": "*",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.85.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
