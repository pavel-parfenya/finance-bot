# Режим работы: polling (локальная разработка) или webhook (продакшн)
MODE=polling
PORT=10000

# Только для webhook-режима
# WEBHOOK_URL=https://your-app.onrender.com/webhook
# WEBHOOK_SECRET=your-random-secret-string
# Базовый URL приложения (для Mini App). В webhook берётся из WEBHOOK_URL. В polling можно задать явно (напр. tuna).
# PUBLIC_BASE_URL=https://xxx.tuna.run

# PostgreSQL (localhost — для запуска вне Docker; в Docker Compose используется postgres)
DATABASE_URL=postgresql://finance:finance@localhost:5432/finance_bot
# Для облачных БД (Render, Neon, Supabase) SSL включается автоматически. Для localhost — отключён.
# DATABASE_SSL=true
# Опционально для docker-compose:
# DB_USER=finance
# DB_PASSWORD=finance
# DB_NAME=finance_bot

TELEGRAM_BOT_TOKEN=your-telegram-bot-token

DEEPSEEK_API_KEY=your-deepseek-api-key

# Whisper-compatible STT provider (OpenAI, Groq, etc.)
WHISPER_API_KEY=your-whisper-api-key
WHISPER_BASE_URL=https://api.groq.com/openai/v1
