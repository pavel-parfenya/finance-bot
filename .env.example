# =============================================================================
# Единый .env для всего монорепо.
# Все приложения читают этот файл (см. packages/server-core/src/config, apps/landing/next.config.js, apps/miniapp, apps/cms/src/index.ts).
# =============================================================================

# =============================================================================
# API + BOT
# =============================================================================

# Режим бота: polling (локально) или webhook (прод).
# Webhook должен указывать на сервис бота (порт BOT_HTTP_PORT), не на API.
MODE=polling

# HTTP-порт Mini App + Nest API
PORT=10000

# HTTP-порт сервиса бота (health, POST /webhook, POST /internal/telegram/send)
BOT_HTTP_PORT=10001

# URL сервиса бота для исходящих сообщений из API (локально совпадает с BOT_HTTP_PORT)
BOT_SERVICE_URL=http://127.0.0.1:10001

# Общий секрет: API шлёт `Authorization: Bearer …` на `/internal/telegram/send`
INTERNAL_BOT_SECRET=change-me-in-production

# Webhook (MODE=webhook): WEBHOOK_URL или RENDER_EXTERNAL_URL — полный URL для setWebhook.
# Отдельный контейнер бота: EMBED_TELEGRAM_BOT=false на API.
# WEBHOOK_URL=https://bot.example.com/webhook
# WEBHOOK_SECRET=your-random-secret-string

# Базовый URL API (Mini App: ${PUBLIC_BASE_URL}/app).
# На Render без явного PUBLIC_BASE_URL можно опереться на RENDER_EXTERNAL_URL.
PUBLIC_BASE_URL=http://127.0.0.1:10000

# Локальная разработка Mini App без Telegram (API_MODE=test требует TELEGRAM_USER_ID)
# API_MODE=test
# TELEGRAM_USER_ID=416264062

# @username супер-админа: админ-аналитика в Mini App (без @)
# SUPER_ADMIN_USERNAME=you
# =============================================================================
# DATABASE (PostgreSQL — общая БД для api/bot)
# =============================================================================

DATABASE_URL=postgresql://finance:finance@localhost:5432/finance_bot
# Для облачных БД SSL включается автоматически. Для localhost — отключён.
# DATABASE_SSL=true
# Опционально для docker-compose:
# DB_USER=finance
# DB_PASSWORD=finance
# DB_NAME=finance_bot
# =============================================================================
# TELEGRAM
# =============================================================================

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# =============================================================================
# AI / STT
# =============================================================================

DEEPSEEK_API_KEY=your-deepseek-api-key

# Whisper-compatible STT (OpenAI, Groq, etc.)
WHISPER_API_KEY=your-whisper-api-key
WHISPER_BASE_URL=https://api.groq.com/openai/v1

# =============================================================================
# LANDING (Next.js — apps/landing)
# =============================================================================

# URL Strapi CMS — источник тарифов/фич (server-core) и SSR-запросов лендинга.
# В docker-сети адрес = ИМЯ СЕРВИСА: http://cms:1337.
# НЕ localhost — внутри api-контейнера localhost это сам контейнер (Strapi там нет),
# тарифы не прочитаются и оплата падает с «Цена тарифа не задана в Strapi».
# Локально (Strapi запущен на хосте): http://localhost:1337.
STRAPI_API_URL=http://cms:1337
# STRAPI_TOKEN=your-strapi-api-token

# Публичное имя бота (для ссылок на лендинге)
NEXT_PUBLIC_BOT_USERNAME=@content_maker_test_1_bot

# Базовый URL API для SSR-запросов лендинга (billing). По умолчанию = PUBLIC_BASE_URL.
# NEXT_PUBLIC_API_URL=http://localhost:10000
# =============================================================================
# CMS (Strapi v5 — apps/cms)
# =============================================================================

STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337

# База данных Strapi: sqlite (разработка) или postgres (прод)
# В режиме postgres Strapi использует ту же БД что и API (DATABASE_URL),
# но в отдельной схеме. Схему нужно создать вручную:
#   CREATE SCHEMA IF NOT EXISTS strapi;
STRAPI_DATABASE_CLIENT=postgres
# STRAPI_DATABASE_CLIENT=postgres
# Схема внутри общей БД
STRAPI_DATABASE_SCHEMA=strapi
# Если нужна отдельная БД вместо общей — задайте явно:
# STRAPI_DATABASE_HOST=localhost
# STRAPI_DATABASE_PORT=5432
# STRAPI_DATABASE_NAME=finance_bot
# STRAPI_DATABASE_USERNAME=finance
# STRAPI_DATABASE_PASSWORD=finance
# STRAPI_DATABASE_SSL=false

# Ключи безопасности Strapi (сгенерировать: openssl rand -base64 32)
STRAPI_APP_KEYS=change-me-1,change-me-2,change-me-3,change-me-4
STRAPI_API_TOKEN_SALT=change-me
STRAPI_ADMIN_JWT_SECRET=change-me
STRAPI_TRANSFER_TOKEN_SALT=change-me
STRAPI_JWT_SECRET=change-me
# =============================================================================
# BILLING (Sprint 3+)
# =============================================================================

# Режим монетизации:
#   free (по умолчанию) — всё бесплатно, подписки/тарифы нигде не показываются
#                         (раздел «Подписка» в Mini App скрыт, API /api/subscription
#                         и /api/billing/* отключены).
#   paid                — подписки активны, реальные оплаты.
#   test                — подписки активны, но bePaid в тестовом режиме (checkout.test=true) —
#                         деньги не списываются (тестовые карты bePaid).
#
# Три рабочих сценария (PAYMENT_MODE + PAYMENT_GATEWAY):
#   1. Прод (на сервере):       PAYMENT_MODE=paid  + PAYMENT_GATEWAY=bepaid → реальные оплаты.
#   2. Тест bePaid (на сервере): PAYMENT_MODE=test  + PAYMENT_GATEWAY=bepaid → тестовые оплаты bePaid.
#   3. Полный мок (локально):    PAYMENT_MODE=test  + PAYMENT_GATEWAY=test  → подписка без обращения к bePaid.
PAYMENT_MODE=free

# JWT секрет для billing-токенов (бот → лендинг → API). Сгенерировать: openssl rand -hex 32
BILLING_JWT_SECRET=change-me-in-production

# Базовый URL публичного лендинга (для ссылки «Купить подписку» из бота)
LANDING_BASE_URL=https://valentinethebuhgalter.by

# Платёжный шлюз:
#   test (по умолчанию) — оплата мокается: checkout сразу оформляет подписку,
#                         банк не вызывается (удобно для разработки/демо).
#   bepaid              — реальная оплата через bePaid: виджет оплаты на лендинге,
#                         подписка активируется по notify-webhook /api/billing/webhook.
PAYMENT_GATEWAY=test

# bePaid (нужны только при PAYMENT_GATEWAY=bepaid).
# Тестовый режим (checkout.test=true) включается через PAYMENT_MODE=test — отдельного флага нет.
# BEPAID_SHOP_ID=
# BEPAID_SECRET_KEY=
# База checkout-API (создание токена виджета):
# BEPAID_CHECKOUT_URL=https://checkout.bepaid.by
# База gateway-API (проверка статуса транзакции в webhook):
# BEPAID_GATEWAY_URL=https://gateway.bepaid.by
# Валюта платежа (тарифы в Strapi указаны в BYN):
# BEPAID_CURRENCY=BYN
