# Корневой `.env`, затем при наличии переопределяют `apps/api/.env` и `apps/bot/.env` (см. `packages/server-core/src/config`).
# Режим бота: polling (локально) или webhook (прод). Webhook должен указывать на **сервис бота** (порт BOT_HTTP_PORT), не на API.
# При `npm run start` из корня поднимаются и API, и бот. Режим webhook без публичного URL на BOT_HTTP_PORT не получит апдейты.
MODE=polling

# HTTP-порт Mini App + Nest API
PORT=10000

# HTTP-порт сервиса бота (health, POST /webhook, POST /internal/telegram/send)
BOT_HTTP_PORT=10001

# URL сервиса бота для исходящих сообщений из API (локально совпадает с BOT_HTTP_PORT)
BOT_SERVICE_URL=http://127.0.0.1:10001

# Общий секрет: API шлёт `Authorization: Bearer …` на `/internal/telegram/send`
INTERNAL_BOT_SECRET=change-me-in-production

# Webhook (MODE=webhook): на одном сервисе с API вебхук = тот же хост + /webhook (вшито в процесс API).
# WEBHOOK_URL или RENDER_EXTERNAL_URL — полный URL вебхука для setWebhook (например https://app.onrender.com/webhook).
# Отдельный контейнер бота: EMBED_TELEGRAM_BOT=false на API и на образе bot задать свой WEBHOOK_URL.
# WEBHOOK_URL=https://bot.example.com/webhook
# WEBHOOK_SECRET=your-random-secret-string

# Базовый URL **API** (Mini App: `${PUBLIC_BASE_URL}/app`, меню в Telegram). Обязателен, если нужна кнопка Mini App.
# Если переменная есть и в корневом `.env`, и в `apps/bot/.env` / `apps/api/.env`, приоритет у значения из корня (удобно при смене туннеля).
# На Render без явного `PUBLIC_BASE_URL` можно опереться на `RENDER_EXTERNAL_URL`.
PUBLIC_BASE_URL=http://127.0.0.1:10000

# PostgreSQL (localhost — вне Docker; в Docker Compose — хост postgres)
DATABASE_URL=postgresql://finance:finance@localhost:5432/finance_bot
# Для облачных БД SSL включается автоматически. Для localhost — отключён.
# DATABASE_SSL=true
# Опционально для docker-compose:
# DB_USER=finance
# DB_PASSWORD=finance
# DB_NAME=finance_bot

TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Локальная разработка Mini App без Telegram: все /api как у пользователя с этим telegram id (обязателен при API_MODE=test)
# API_MODE=test
# TELEGRAM_USER_ID=416264062

DEEPSEEK_API_KEY=your-deepseek-api-key

# Whisper-compatible STT provider (OpenAI, Groq, etc.)
WHISPER_API_KEY=your-whisper-api-key
WHISPER_BASE_URL=https://api.groq.com/openai/v1

# @username супер-админа для /app-stats (без @)
# SUPER_ADMIN_USERNAME=you
