# Режим работы: polling (локальная разработка) или webhook (продакшн)
MODE=polling
PORT=10000

# Только для webhook-режима (на Render заполняется автоматически через RENDER_EXTERNAL_URL)
# WEBHOOK_URL=https://your-app.onrender.com/webhook
# WEBHOOK_SECRET=your-random-secret-string

TELEGRAM_BOT_TOKEN=your-telegram-bot-token

DEEPSEEK_API_KEY=your-deepseek-api-key

# Whisper-compatible STT provider (OpenAI, Groq, etc.)
WHISPER_API_KEY=your-whisper-api-key
WHISPER_BASE_URL=https://api.groq.com/openai/v1

GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_WORKSHEET_NAME=Расходы
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
